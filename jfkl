<!-- ══════════════ SCRIPT ══════════════ -->
<script>
// ── PASSWORD (change this to your own!) ──
const OWNER_PASSWORD = 'gosalram2024';

// ── DEFAULT DATA ──
const DEFAULTS = {
  about: {
    p1: "I'm an MBA graduate specializing in Finance and Operations, driven by a passion for data-driven decision making and operational excellence.",
    p2: "With a strong foundation in analytical tools like SAP FICO, IBM SPSS, and Power BI, I bridge the gap between financial strategy and operational efficiency.",
    p3: "I'm currently seeking opportunities to contribute as a Financial Analyst or Operations Specialist."
  },
  techSkills: ['📊 SAP FICO','📈 IBM SPSS','📋 MS Excel','🔵 Power BI','💼 Microsoft 365','🎨 Canva'],
  softSkills: ['💬 Communication','🔍 Problem Solving','🤝 Teamwork','⏱ Time Management','🔄 Adaptability','🧠 Analytical Thinking'],
  projects: [
    {title:'Industry 4.0 Financial Study', desc:'Analyzed cost efficiency and sustainability impact across manufacturing processes.', link:'Industry4_project.pdf'},
    {title:'Organizational Performance Study', desc:'Identified productivity gaps and operational improvements within organizational structures.', link:'Sodecia_project.pdf'}
  ],
  certs: [
    {name:'SAP FICO', issuer:'SAP Certified', link:'sap_fico_certificate.pdf', icon:'📊'},
    {name:'Business Analytics', issuer:'Professional Certificate', link:'business_analytics_certificate.pdf', icon:'📈'},
    {name:'NISM SEBI Investor Awareness', issuer:'SEBI · NISM', link:'nism_certificate.pdf', icon:'🏦'},
    {name:'Emerging Technologies for Managers', issuer:'Professional Development', link:'emerging_tech_certificate.pdf', icon:'🚀'}
  ]
};

// ── STORAGE HELPERS ──
function load(key, def){ try{ const v=localStorage.getItem(key); return v?JSON.parse(v):def; }catch(e){ return def; } }
function save(key, val){ localStorage.setItem(key, JSON.stringify(val)); }

// ── VISITOR TRACKING ──
function trackVisit(){
  const now = Date.now();
  const today = new Date().toDateString();
  const weekAgo = now - 7*24*60*60*1000;

  let stats = load('gn_visits', {total:0, today:0, todayDate:'', week:[], unique:0});
  const sessions = load('gn_sessions', []);

  // Total
  stats.total++;

  // Today
  if(stats.todayDate !== today){ stats.today = 0; stats.todayDate = today; }
  stats.today++;

  // Week
  stats.week = (stats.week||[]).filter(t => t > weekAgo);
  stats.week.push(now);

  // Unique sessions (session = 30 min window)
  const lastSession = sessions.length ? sessions[sessions.length-1] : 0;
  if(now - lastSession > 30*60*1000){ sessions.push(now); stats.unique = sessions.length; save('gn_sessions', sessions); }

  save('gn_visits', stats);
}

function loadVisitorUI(){
  const stats = load('gn_visits', {total:0, today:0, week:[], unique:0});
  document.getElementById('dash-total-visits').textContent = stats.total||0;
  document.getElementById('dash-today').textContent = stats.today||0;
  document.getElementById('dash-week').textContent = (stats.week||[]).length;
  document.getElementById('dash-unique').textContent = stats.unique||0;
}

function resetVisitors(){
  if(confirm('Reset all visitor data?')){ save('gn_visits',{total:0,today:0,todayDate:'',week:[],unique:0}); save('gn_sessions',[]); loadVisitorUI(); }
}

// ── RENDER SITE ──
function renderSite(){
  const about = load('gn_about', DEFAULTS.about);
  document.getElementById('about-p1').innerHTML = about.p1;
  document.getElementById('about-p2').innerHTML = about.p2;
  document.getElementById('about-p3').innerHTML = about.p3;

  const tech = load('gn_tech', DEFAULTS.techSkills);
  const soft = load('gn_soft', DEFAULTS.softSkills);
  document.getElementById('tech-skills-display').innerHTML = tech.map(s=>`<span class="skill-pill skill-pill-tech">${s}</span>`).join('');
  document.getElementById('soft-skills-display').innerHTML = soft.map(s=>`<span class="skill-pill skill-pill-soft">${s}</span>`).join('');

  const projects = load('gn_projects', DEFAULTS.projects);
  document.getElementById('projects-display').innerHTML = projects.map((p,i)=>`
    <div class="project-card">
      <div class="project-num">0${i+1}</div>
      <div class="project-title">${p.title}</div>
      <div class="project-desc">${p.desc}</div>
      <a href="${p.link}" class="project-link" target="_blank">View Project ↗</a>
    </div>`).join('');

  const certs = load('gn_certs', DEFAULTS.certs);
  const certIcons = ['📊','📈','🏦','🚀','🎓','📜','🏆','⭐'];
  document.getElementById('certs-display').innerHTML = certs.map((c,i)=>`
    <a href="${c.link}" class="cert-card" target="_blank">
      <div class="cert-icon">${c.icon||certIcons[i%certIcons.length]}</div>
      <div><div class="cert-name">${c.name}</div><div class="cert-issuer">${c.issuer}</div></div>
    </a>`).join('');
}

// ── DASHBOARD LOAD ──
function loadDashboard(){
  loadVisitorUI();

  const about = load('gn_about', DEFAULTS.about);
  document.getElementById('edit-p1').value = about.p1;
  document.getElementById('edit-p2').value = about.p2;
  document.getElementById('edit-p3').value = about.p3;

  renderSkillLists();
  renderProjectList();
  renderCertList();
}

// ABOUT SAVE
function saveAbout(){
  save('gn_about',{p1:document.getElementById('edit-p1').value, p2:document.getElementById('edit-p2').value, p3:document.getElementById('edit-p3').value});
  renderSite(); flash('msg-about');
}

// SKILLS
function renderSkillLists(){
  const tech = load('gn_tech', DEFAULTS.techSkills);
  const soft = load('gn_soft', DEFAULTS.softSkills);
  document.getElementById('tech-list-edit').innerHTML = tech.map((s,i)=>`<div class="item-row"><span>${s}</span><button class="del-btn" onclick="delSkill('tech',${i})">Remove</button></div>`).join('');
  document.getElementById('soft-list-edit').innerHTML = soft.map((s,i)=>`<div class="item-row"><span>${s}</span><button class="del-btn" onclick="delSkill('soft',${i})">Remove</button></div>`).join('');
}
function addSkill(type){
  const inp = document.getElementById(`new-${type}`);
  if(!inp.value.trim()) return;
  const key = type==='tech'?'gn_tech':'gn_soft';
  const def = type==='tech'?DEFAULTS.techSkills:DEFAULTS.softSkills;
  const arr = load(key, def); arr.push(inp.value.trim()); save(key, arr); inp.value=''; renderSkillLists();
}
function delSkill(type, idx){
  const key = type==='tech'?'gn_tech':'gn_soft';
  const def = type==='tech'?DEFAULTS.techSkills:DEFAULTS.softSkills;
  const arr = load(key, def); arr.splice(idx,1); save(key, arr); renderSkillLists();
}
function saveSkills(){ renderSite(); flash('msg-skills'); }

// PROJECTS
function renderProjectList(){
  const projects = load('gn_projects', DEFAULTS.projects);
  document.getElementById('projects-list-edit').innerHTML = projects.map((p,i)=>`<div class="item-row"><span>${p.title}</span><button class="del-btn" onclick="delProject(${i})">Remove</button></div>`).join('');
}
function addProject(){
  const t=document.getElementById('new-proj-title').value.trim();
  const d=document.getElementById('new-proj-desc').value.trim();
  const l=document.getElementById('new-proj-link').value.trim();
  if(!t) return;
  const arr=load('gn_projects',DEFAULTS.projects);
  arr.push({title:t,desc:d||'',link:l||'#'});
  save('gn_projects',arr);
  document.getElementById('new-proj-title').value='';
  document.getElementById('new-proj-desc').value='';
  document.getElementById('new-proj-link').value='';
  renderProjectList(); renderSite(); flash('msg-projects');
}
function delProject(i){ const arr=load('gn_projects',DEFAULTS.projects); arr.splice(i,1); save('gn_projects',arr); renderProjectList(); renderSite(); }

// CERTS
function renderCertList(){
  const certs=load('gn_certs',DEFAULTS.certs);
  document.getElementById('certs-list-edit').innerHTML=certs.map((c,i)=>`<div class="item-row"><span>${c.name}</span><button class="del-btn" onclick="delCert(${i})">Remove</button></div>`).join('');
}
function addCert(){
  const n=document.getElementById('new-cert-name').value.trim();
  const is=document.getElementById('new-cert-issuer').value.trim();
  const l=document.getElementById('new-cert-link').value.trim();
  if(!n) return;
  const arr=load('gn_certs',DEFAULTS.certs);
  arr.push({name:n,issuer:is||'',link:l||'#',icon:'🎓'});
  save('gn_certs',arr);
  document.getElementById('new-cert-name').value='';
  document.getElementById('new-cert-issuer').value='';
  document.getElementById('new-cert-link').value='';
  renderCertList(); renderSite(); flash('msg-certs');
}
function delCert(i){ const arr=load('gn_certs',DEFAULTS.certs); arr.splice(i,1); save('gn_certs',arr); renderCertList(); renderSite(); }

// FLASH MSG
function flash(id){ const el=document.getElementById(id); el.classList.add('show'); setTimeout(()=>el.classList.remove('show'),2500); }

// ── AUTH ──
function openOwner(){ document.getElementById('loginModal').classList.add('open'); document.getElementById('pwdInput').focus(); }
function doLogin(){
  const pwd = document.getElementById('pwdInput').value;
  if(pwd === OWNER_PASSWORD){
    document.getElementById('loginModal').classList.remove('open');
    document.getElementById('pwdInput').value='';
    document.getElementById('loginError').style.display='none';
    document.getElementById('dashModal').classList.add('open');
    loadDashboard();
  } else {
    document.getElementById('loginError').style.display='block';
    document.getElementById('pwdInput').value='';
  }
}
function doLogout(){ document.getElementById('dashModal').classList.remove('open'); }
function closeModals(){
  document.getElementById('loginModal').classList.remove('open');
  document.getElementById('dashModal').classList.remove('open');
  document.getElementById('pwdInput').value='';
  document.getElementById('loginError').style.display='none';
}

// ── TABS ──
function switchTab(name, btn){
  document.querySelectorAll('.dash-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.dash-panel').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('panel-'+name).classList.add('active');
  if(name==='visitors') loadVisitorUI();
}

// ── THEME ──
function toggleTheme(){ const l=document.body.classList.toggle('light'); document.querySelector('.theme-btn').textContent=l?'🌙':'☀️'; }

// ── MOBILE MENU ──
function toggleMenu(){ document.getElementById('navLinks').classList.toggle('open'); }
document.querySelectorAll('.nav-links a').forEach(a=>a.addEventListener('click',()=>document.getElementById('navLinks').classList.remove('open')));

// ── SCROLL REVEAL ──
const reveals=document.querySelectorAll('.reveal');
const observer=new IntersectionObserver(entries=>{ entries.forEach((e,i)=>{ if(e.isIntersecting){ e.target.style.transitionDelay=(i*.05)+'s'; e.target.classList.add('visible'); } }); },{threshold:.1});
reveals.forEach(r=>observer.observe(r));

// ── NAVBAR SHADOW ──
window.addEventListener('scroll',()=>{ document.getElementById('navbar').style.boxShadow=window.scrollY>40?'0 4px 32px rgba(0,0,0,.4)':'none'; });

// ── CLOSE MODAL ON OUTSIDE CLICK ──
document.getElementById('loginModal').addEventListener('click',function(e){ if(e.target===this) closeModals(); });
document.getElementById('dashModal').addEventListener('click',function(e){ if(e.target===this) closeModals(); });

// ── INIT ──
trackVisit();
renderSite();
</script>
